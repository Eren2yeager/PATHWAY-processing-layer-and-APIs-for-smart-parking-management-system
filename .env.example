# Pathway Configuration
PATHWAY_HOST=0.0.0.0
PATHWAY_PORT=8000
PATHWAY_LOG_LEVEL=INFO

# Roboflow API
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_WORKSPACE=your_workspace
ROBOFLOW_LICENSE_PLATE_PROJECT=license-plate-detection
ROBOFLOW_LICENSE_PLATE_VERSION=1
ROBOFLOW_PARKING_SLOT_PROJECT=parking-slot-detection
ROBOFLOW_PARKING_SLOT_VERSION=1

# Detection Thresholds
PLATE_DETECTION_CONFIDENCE=0.4
PARKING_SLOT_CONFIDENCE=0.4
VEHICLE_DETECTION_CONFIDENCE=0.5

# Frame Processing
GATE_FRAME_SKIP=10
LOT_FRAME_SKIP=20
DUPLICATE_DETECTION_WINDOW=10

# Next.js Integration
NEXTJS_API_URL=http://localhost:3000
NEXTJS_WEBHOOK_ENTRY=/api/pathway/webhook/entry
NEXTJS_WEBHOOK_EXIT=/api/pathway/webhook/exit
NEXTJS_WEBHOOK_CAPACITY=/api/pathway/webhook/capacity

# Performance
MAX_CONCURRENT_STREAMS=10
BUFFER_SIZE=100
